# Copy to `.env` and fill in. .env is read by run_pipeline.py at startup.
# Never commit your real .env.

ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Optional: force the dispatcher into dry-run for every step
# DRY_RUN=1

# Optional: override the default model used when an agent's config.json
# does not specify one. Defaults to claude-sonnet-4-5 in code.
# DEFAULT_MODEL=claude-sonnet-4-5
